# Cursor: reduce indexing noise — gitignore-like syntax.
# Intentionally still indexed: src/, docs/, supabase/ (migrations, config), .cursor/,
# package.json, lockfiles, tsconfig*, vite.config.*, tailwind*, postcss*, src/**/vite-env.d.ts

#------------------------------------------------------------------------------
# Dependencies & package managers
#------------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log*

.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

#------------------------------------------------------------------------------
# Builds & frontend generated output (Vite / PWA)
#------------------------------------------------------------------------------
dist/
build/
out/
.output/
.vercel/output/

.vite/
dev-dist/

# TS incremental / project references
/tsconfig.tsbuildinfo
*.tsbuildinfo

# Source maps emitted next to bundles
*.js.map

# Service worker / workbox under typical emit dirs only (not src/hand-written SW)
**/dist/**/sw.js
**/dist/**/registerSW.js
**/dist/**/workbox-*.js
**/dev-dist/**/sw.js

#------------------------------------------------------------------------------
# Tests, coverage & reports
#------------------------------------------------------------------------------
coverage/
.nyc_output/
.jest-cache/
**/test-results/
**/playwright-report/
**/blob-report/
**/html-report/

cypress/screenshots/
cypress/videos/
cypress/downloads/

**/__screenshots__/
**/.lighthouseci/

*.lcov
junit.xml
*.trx

#------------------------------------------------------------------------------
# Environment & secrets (templates stay visible via negation)
#------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

*.pem
*.key
*_rsa
*_dsa
*_ecdsa
*_ed25519

# Local SQLite journals / dumps where applicable
*.db-journal

#------------------------------------------------------------------------------
# Supabase CLI / local
#------------------------------------------------------------------------------
supabase/.temp/
.supabase/

#------------------------------------------------------------------------------
# Tool caches
#------------------------------------------------------------------------------
.turbo/
.parcel-cache/
.stylelintcache
.eslintcache
.prettier-cache
.cache/
.temp/
.tmp/

*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

#------------------------------------------------------------------------------
# Editors, IDE, OS
#------------------------------------------------------------------------------
.idea/
*.swp
*.swo

.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

.history/
*.vsix

.DS_Store
Thumbs.db
desktop.ini

.vs/

#------------------------------------------------------------------------------
# Visual Studio / .NET build dirs (aligned with repo .gitignore)
#------------------------------------------------------------------------------
[Dd]ebug/
[Rr]elease/
[Oo]bj/
[Bb]in/
artifacts/