# Copy to `.env.local` for Vite (`npm run dev`). Never commit real keys.
# Local Supabase: `npm run supabase:start`, then `npm run supabase:status` for keys.
# CI uses placeholder VITE_* values from `.github/workflows/main-protection.yml` (stubbed E2E).

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
